# Porta do servidor
FOOD_PORT=8000

# Modo de desenvolvimento (hot-reload)
DEVELOPMENT=0

# Horário de abertura e fechamento do cardápio (HH:MM)
MENU_OPEN_HOUR=7:00
MENU_CLOSE_HOUR=10:30

# Itens automáticos do cardápio (separados por vírgula)
AUTOMATIC_MENU_ITEMS=Arroz,Feijão,Salada

# Configuração de e-mail SMTP
MAIL_SMTP_SERVER=smtp.example.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=usuario@example.com
MAIL_SMTP_PASSWORD=senha_aqui
MAIL_TO=destinatario1@example.com;destinatario2@example.com

# Banco de dados
DATABASE_URL=sqlite:///./data/food.db

# CORS - origens permitidas (separadas por vírgula)
CORS_ORIGINS=http://localhost:3000
